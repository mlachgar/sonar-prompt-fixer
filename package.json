{
  "name": "sonar-prompt-fixer",
  "displayName": "Sonar Prompt Fixer",
  "description": "Connect reusable SonarQube profiles, switch workspace projects, and turn Sonar findings into remediation prompts in VS Code.",
  "version": "0.0.2",
  "publisher": "mohamedlachgar",
  "license": "MIT",
  "icon": "media/icons/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlachgar/sonar-prompt-fixer.git"
  },
  "homepage": "https://github.com/mlachgar/sonar-prompt-fixer#readme",
  "bugs": {
    "url": "https://github.com/mlachgar/sonar-prompt-fixer/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "sonarqube",
    "sonarcloud",
    "sonar",
    "monorepo",
    "project-selector",
    "developer-tools",
    "prompt",
    "codex",
    "claude",
    "qwen",
    "static-analysis",
    "code-quality"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sonarPromptFixer",
          "title": "Sonar Prompt Fixer",
          "icon": "media/sonar.svg"
        }
      ]
    },
    "views": {
      "sonarPromptFixer": [
        {
          "id": "sonarPromptFixer.issues",
          "type": "webview",
          "name": "Findings",
          "icon": "media/sonar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "sonarPromptFixer.openConfigurationEditor",
        "title": "Sonar Prompt Fixer: Open Configuration Editor",
        "icon": "$(gear)"
      },
      {
        "command": "sonarPromptFixer.openIssuesWorkspace",
        "title": "Sonar Prompt Fixer: Open Sonar Workspace",
        "icon": "$(layout)"
      },
      {
        "command": "sonarPromptFixer.resetState",
        "title": "Sonar Prompt Fixer: Reset Connections And Projects",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sonarPromptFixer.openConfigurationEditor",
          "when": "view == sonarPromptFixer.issues",
          "group": "navigation"
        },
        {
          "command": "sonarPromptFixer.openIssuesWorkspace",
          "when": "view == sonarPromptFixer.issues",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Sonar Prompt Fixer",
      "properties": {
        "sonarPromptFixer.groupBy": {
          "type": "string",
          "enum": [
            "severity",
            "type"
          ],
          "default": "severity",
          "description": "How to group issues in the tree view."
        },
        "sonarPromptFixer.prompt.defaultTarget": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "qwen"
          ],
          "default": "codex",
          "description": "Default target model for prompt rendering."
        },
        "sonarPromptFixer.prompt.defaultStyle": {
          "type": "string",
          "enum": [
            "minimal",
            "balanced",
            "guided"
          ],
          "default": "balanced",
          "description": "Default prompt style."
        },
        "sonarPromptFixer.connections.activeProfileId": {
          "type": "string",
          "default": "",
          "description": "Active saved Sonar connection profile id."
        },
        "sonarPromptFixer.projects.activeProjectPath": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "Active workspace Sonar project directory selected from discovered sonar-project.properties files."
        },
        "sonarPromptFixer.connections.profiles": {
          "type": "array",
          "default": [],
          "description": "Saved Sonar connection profiles managed by the configuration editor.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "connection"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "connection": {
                "type": "object",
                "required": [
                  "type",
                  "baseUrl"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "cloud",
                      "server"
                    ]
                  },
                  "baseUrl": {
                    "type": "string"
                  },
                  "branch": {
                    "type": "string"
                  },
                  "pullRequest": {
                    "type": "string"
                  },
                  "verifyTls": {
                    "type": "boolean"
                  },
                  "authMode": {
                    "type": "string",
                    "enum": [
                      "bearer",
                      "basicToken"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "tsc -p ./ --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4",
    "vsce": "^2.15.0"
  }
}
